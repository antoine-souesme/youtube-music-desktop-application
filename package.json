{
    "name": "youtube-music-desktop-application",
    "version": "0.0.1",
    "description": "Simple wrapper for Youtube Music, for easy account switching. Made with electron",
    "license": "ISC",
    "author": "antoine.souesme",
    "type": "commonjs",
    "main": "src/main.js",
    "scripts": {
        "dev": "electron .",
        "start": "electron .",
        "build": "electron-builder",
        "build:mac": "electron-builder --mac",
        "build:win": "electron-builder --win",
        "build:linux": "electron-builder --linux"
    },
    "devDependencies": {
        "electron": "^35.3.0",
        "electron-builder": "^26.0.12"
    },
    "build": {
        "appId": "com.youtube.music.desktop.application",
        "productName": "YouTube Music Desktop Application",
        "files": [
            "src/**/*",
            "build/icons/**/*",
            "package.json"
        ],
        "directories": {
            "output": "dist"
        },
        "mac": {
            "target": [
                "dmg"
            ],
            "category": "public.app-category.music",
            "icon": "build/icons/icon.icns"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "build/icons/icon.ico"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "icon": "build/icons/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
